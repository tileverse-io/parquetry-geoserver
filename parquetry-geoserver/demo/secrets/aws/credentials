# Demo-only credentials for the bundled s3proxy emulator. NOT real AWS keys.
# This mirrors how a real deployment supplies credentials: the GeoServer container reads them
# from ~/.aws/credentials (the AWS default credential chain), and the parquetry-s3 datastores
# carry NO inline keys. On real AWS you would instead use an instance role or env vars.
[default]
aws_access_key_id = parquetry-demo
aws_secret_access_key = parquetry-demo-secret
