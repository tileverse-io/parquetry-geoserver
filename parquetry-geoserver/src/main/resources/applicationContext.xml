<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
             http://www.springframework.org/schema/beans
             http://www.springframework.org/schema/beans/spring-beans.xsd">

  <!--
    Binds the GeoParquet DataStore factory to its custom store edit panel.
    componentClass selects GeoParquetDataStoreEditPanel, whose form reacts to the
    chosen storage provider and exposes provider-specific connection parameters.
  -->
  <bean id="geoParquetDataStorePanel" class="org.geoserver.web.data.resource.DataStorePanelInfo">
    <property name="id" value="geoparquet"/>
    <property name="factoryClass" value="io.tileverse.parquetry.geotools.parquet.GeoParquetDataStoreFactory"/>
    <property name="componentClass" value="io.tileverse.parquetry.geoserver.web.GeoParquetDataStoreEditPanel"/>
    <property name="icon" value="gs-icon-page-white-vector"/>
  </bean>

  <!--
    Binds the Iceberg DataStore factory to the same edit panel as GeoParquet.
    Being single-backend (one storage.provider param, like GeoParquet), the
    Iceberg store reuses the single-select panel that renders the grouped,
    provider-driven storage parameters. componentClass keeps the historical
    GeoParquetDataStoreEditPanel name even though the panel is store-neutral.
  -->
  <bean id="icebergDataStorePanel" class="org.geoserver.web.data.resource.DataStorePanelInfo">
    <property name="id" value="iceberg"/>
    <property name="factoryClass" value="io.tileverse.parquetry.geotools.iceberg.IcebergDataStoreFactory"/>
    <property name="componentClass" value="io.tileverse.parquetry.geoserver.web.GeoParquetDataStoreEditPanel"/>
    <property name="icon" value="gs-icon-page-white-vector"/>
  </bean>

  <!--
    Binds the STAC GeoParquet DataStore factory to its own edit panel. A STAC catalog can read from more than one
    storage backend at once (its catalog and its data assets may live on different backends). Unlike the single-select
    GeoParquet/Iceberg panel, this one offers a multi-select of backends and has no storage.provider parameter.
    componentClass selects StacDataStoreEditPanel.
  -->
  <bean id="stacDataStorePanel" class="org.geoserver.web.data.resource.DataStorePanelInfo">
    <property name="id" value="geoparquet-stac"/>
    <property name="factoryClass" value="io.tileverse.parquetry.geotools.parquet.StacDataStoreFactory"/>
    <property name="componentClass" value="io.tileverse.parquetry.geoserver.web.StacDataStoreEditPanel"/>
    <property name="icon" value="gs-icon-page-white-vector"/>
  </bean>

  <bean id="parquetryModuleStatus" class="org.geoserver.platform.ModuleStatusImpl">
    <property name="module" value="gs-parquetry"/>
    <property name="name" value="Parquetry GeoParquet Plugin"/>
    <property name="component" value="GeoParquet DataStore"/>
    <property name="available" value="true"/>
    <property name="enabled" value="true"/>
    <property name="category" value="COMMUNITY"/>
  </bean>
</beans>
